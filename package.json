{
  "name": "typst-wasm-workspace",
  "private": true,
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "build": "turbo run build",
    "test": "pnpm run test:unit",
    "test:unit": "pnpm -r --if-present test:unit",
    "test:integration": "pnpm -r --if-present test:integration",
    "test:browser": "turbo run test:browser",
    "test:runtime:node-worker": "pnpm --filter typst-wasm run test:integration:node:worker",
    "test:runtime:node-jspi": "pnpm --filter typst-wasm run test:integration:node:jspi",
    "test:runtime:bun-worker": "pnpm --filter typst-wasm run test:integration:bun:worker",
    "test:runtime:deno-worker": "pnpm --filter typst-wasm run test:integration:deno:worker",
    "test:runtime:browser": "pnpm --filter typst-wasm run test:browser",
    "test:runtime:workerd": "pnpm --filter @typst-wasm/example-typst-playground-cloudflare run build && pnpm --filter @typst-wasm/example-typst-playground-cloudflare exec wrangler deploy --dry-run --outdir .workerd-artifact && node packages/typst-wasm/scripts/workerd-smoke.mjs",
    "fix": "pnpm -r --if-present fix",
    "format": "turbo run format",
    "changeset": "changeset",
    "lint": "turbo run lint",
    "version-packages": "changeset version && pnpm install --lockfile-only",
    "release": "pnpm turbo run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.7",
    "turbo": "^2.6.3",
    "vercel": "52.0.0"
  }
}

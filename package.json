{
  "name": "typst-wasm-workspace",
  "private": true,
  "packageManager": "pnpm",
  "scripts": {
    "fix": "pnpm -r --if-present fix",
    "release": "release-it"
  },
  "devDependencies": {
    "@release-it/bumper": "^7.0.6",
    "release-it": "^19.0.5"
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release v${version}",
      "tagName": "v${version}",
      "requireCleanWorkingDir": true
    },
    "github": {
      "release": false
    },
    "npm": false,
    "plugins": {
      "@release-it/bumper": {
        "in": "packages/typst-wasm/package.json",
        "out": [
          "packages/fonts/package.json",
          {
            "file": "packages/engine-wasm/package.json",
            "path": "version"
          },
          {
            "file": "packages/engine-wasm/Cargo.toml",
            "path": "package.version"
          },
          {
            "file": "packages/typst-wasm/package.json",
            "path": "version"
          }
        ]
      }
    },
    "hooks": {
      "after:bump": "cargo generate-lockfile --manifest-path packages/engine-wasm/Cargo.toml && pnpm install --lockfile-only"
    }
  }
}

{
  "name": "@typst-wasm/example-typst-blog",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "build": "nix run ../..#build-artifact -- example-typst-blog",
    "dev": "node --experimental-wasm-jspi ./node_modules/vite/bin/vite.js dev",
    "preview": "node --experimental-wasm-jspi ./node_modules/vite/bin/vite.js preview",
    "typecheck": "tsc --noEmit",
    "format": "pnpm exec prettier . --check",
    "format:fix": "pnpm exec prettier . --write"
  },
  "dependencies": {
    "@tailwindcss/vite": "4.3.1",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-start": "^1.168.26",
    "@typst-wasm/fonts": "workspace:*",
    "@typst-wasm/vite-plugin-typst": "workspace:*",
    "@vitejs/plugin-react": "^6.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "4.3.1",
    "typst-wasm": "workspace:*",
    "vite": "^8.0.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.42.3",
    "@tailwindcss/typography": "^0.5.20",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "wrangler": "^4.105.0",
    "prettier": "^3.8.4"
  }
}

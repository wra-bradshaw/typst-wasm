{
  "name": "@typst-wasm/docs",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "nix run ../..#build-artifact -- docs",
    "build:local": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro sync && tsc --noEmit",
    "format": "pnpm exec prettier . --check",
    "format:fix": "pnpm exec prettier . --write"
  },
  "dependencies": {
    "@astrojs/starlight": "0.41.3",
    "astro": "7.0.2",
    "sharp": "0.34.5",
    "starlight-typedoc": "0.23.0",
    "typedoc": "0.28.20",
    "typedoc-plugin-markdown": "4.12.0",
    "typst-wasm": "workspace:*",
    "@typst-wasm/vite-plugin-typst": "workspace:*"
  },
  "devDependencies": {
    "prettier": "^3.8.4",
    "typescript": "^5.9.3"
  }
}

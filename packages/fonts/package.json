{
  "name": "@typst-wasm/fonts",
  "version": "0.3.0",
  "type": "module",
  "main": "./index.js",
  "types": "./index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wra-bradshaw/typst-wasm.git"
  },
  "bugs": {
    "url": "https://github.com/wra-bradshaw/typst-wasm/issues"
  },
  "homepage": "https://github.com/wra-bradshaw/typst-wasm#readme",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "browser": {
        "types": "./index.d.ts",
        "default": "./index.browser.js"
      },
      "workerd": {
        "types": "./index.d.ts",
        "default": "./index.browser.js"
      },
      "worker": {
        "types": "./index.d.ts",
        "default": "./index.browser.js"
      },
      "default": "./index.js"
    }
  },
  "scripts": {
    "build": "nix run ../..#build-artifact -- fonts",
    "fix": "pnpm exec prettier . --write",
    "format": "pnpm exec prettier . --check",
    "format:fix": "pnpm exec prettier . --write"
  },
  "files": [
    "index.js",
    "index.browser.js",
    "index.d.ts",
    "dist"
  ],
  "devDependencies": {
    "prettier": "^3.8.4"
  }
}

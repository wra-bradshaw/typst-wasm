{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "typst-wasm/engine": ["./src/engine/generated/jspi"],
      "typst-wasm/engine/worker": ["./src/engine/generated/worker"],
      "typst-wasm/engine/types": [
        "./src/engine/generated/jspi/interfaces/typst-engine-types.d.ts"
      ]
    },
    "types": ["tsdown-plugin-worker/types"]
  }
}

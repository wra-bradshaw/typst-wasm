{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "declaration": true,
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@typst-wasm/fonts": ["../fonts"],
      "@typst-wasm/engine-wasm": ["../engine-wasm"]
    },
    "types": ["tsdown-plugin-worker/types"]
  }
}

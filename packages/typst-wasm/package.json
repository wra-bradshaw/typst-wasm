{
  "name": "typst-wasm",
  "version": "0.3.0",
  "description": "Typst WebAssembly compiler service with worker and JSPI backends",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": {
        "types": "./dist/index.browser.d.ts",
        "default": "./dist/index.browser.js"
      },
      "workerd": {
        "types": "./dist/index.workerd.d.ts",
        "default": "./dist/index.workerd.js"
      },
      "worker": {
        "types": "./dist/index.workerd.d.ts",
        "default": "./dist/index.workerd.js"
      },
      "default": "./dist/index.js"
    },
    "./files": {
      "types": "./dist/files.d.ts",
      "default": "./dist/files.js"
    },
    "./worker/node": {
      "types": "./dist/worker/node.d.ts",
      "default": "./dist/worker/node.js"
    },
    "./worker/browser": {
      "types": "./dist/worker/browser.d.ts",
      "default": "./dist/worker/browser.js"
    }
  },
  "files": [
    "dist"
  ],
  "author": "will-lol",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wra-bradshaw/typst-wasm.git"
  },
  "bugs": {
    "url": "https://github.com/wra-bradshaw/typst-wasm/issues"
  },
  "homepage": "https://github.com/wra-bradshaw/typst-wasm#readme",
  "scripts": {
    "build": "nix run ../..#build-artifact -- typst-wasm",
    "fix": "pnpm run format:fix && pnpm exec eslint . --fix",
    "lint": "pnpm exec eslint . --max-warnings=0 && pnpm exec tsc --noEmit",
    "test": "pnpm run test:unit && pnpm run test:integration",
    "test:unit": "pnpm exec vitest run",
    "test:integration": "pnpm run test:integration:bun && pnpm run test:integration:node && pnpm run test:integration:workerd && pnpm run test:integration:deno && pnpm run test:integration:browser",
    "test:integration:bun": "bun test ./tests/integration/adapters/bun.ts",
    "test:integration:node": "node --experimental-strip-types --experimental-wasm-jspi --test-isolation=none --test tests/integration/adapters/node.ts",
    "test:integration:workerd": "pnpm exec vitest run -c vitest.workerd.config.ts",
    "test:integration:deno": "deno test --no-check --allow-read --allow-net --allow-env tests/integration/adapters/deno.ts",
    "test:integration:browser": "pnpm exec vitest run -c vitest.browser.config.ts",
    "format": "pnpm exec prettier . --check",
    "format:fix": "pnpm exec prettier . --write",
    "knip": "pnpm exec knip"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.18.0",
    "@cloudflare/workers-types": "^5.20260705.1",
    "@eslint/js": "^10.0.1",
    "@std/expect": "jsr:^1.0.20",
    "@types/bun": "^1.3.9",
    "@types/deno": "^2.5.0",
    "@types/node": "^25.2.0",
    "@typst-wasm/fonts": "workspace:*",
    "@vitest/browser-playwright": "4.1.2",
    "eslint": "^10.0.0",
    "knip": "^6.17.1",
    "playwright": "1.61.1",
    "prettier": "^3.8.4",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0",
    "vite": "7.3.5",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@typst-wasm/engine-wasm": "workspace:*",
    "nanotar": "^0.2.0",
    "tsdown-plugin-worker": "^0.1.6"
  }
}

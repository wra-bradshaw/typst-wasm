{
  "name": "typst-wasm",
  "version": "0.2.0",
  "description": "Typst WebAssembly compiler service with worker and JSPI backends",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./fonts": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./wasm": {
      "types": "./dist/wasm.d.ts",
      "default": "./dist/wasm.js"
    }
  },
  "files": [
    "dist"
  ],
  "author": "will-lol",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wra-bradshaw/typst-wasm.git"
  },
  "bugs": {
    "url": "https://github.com/wra-bradshaw/typst-wasm/issues"
  },
  "homepage": "https://github.com/wra-bradshaw/typst-wasm#readme",
  "scripts": {
    "build": "nix run ../..#build-artifact -- typst-wasm",
    "fix": "pnpm run format:fix && pnpm exec eslint . --fix",
    "lint": "pnpm exec eslint . --max-warnings=0",
    "test": "pnpm exec vitest run",
    "e2e": "pnpm run e2e:node && pnpm run e2e:bun && pnpm run e2e:deno",
    "e2e:node": "node --experimental-wasm-stack-switching ./node_modules/vitest/vitest.mjs run -c vitest.e2e.config.ts --pool vmThreads",
    "e2e:bun": "bun test ./tests/e2e/bun.e2e.ts",
    "e2e:deno": "deno test --no-check --allow-read --allow-net tests/e2e/deno.e2e.ts",
    "format": "pnpm exec prettier . --check",
    "format:fix": "pnpm exec prettier . --write",
    "knip": "pnpm exec knip"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.9",
    "@types/deno": "^2.5.0",
    "@types/node": "^25.2.0",
    "eslint": "^10.0.0",
    "knip": "^6.17.1",
    "prettier": "^3.8.4",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "@typst-wasm/engine-wasm": "workspace:*",
    "@typst-wasm/fonts": "workspace:*",
    "nanotar": "^0.2.0",
    "tsdown-plugin-worker": "^0.1.6"
  }
}

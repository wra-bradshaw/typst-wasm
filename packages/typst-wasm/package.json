{
  "name": "typst-wasm",
  "version": "0.1.0",
  "description": "Typst WebAssembly compiler service with worker and JSPI backends",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./fonts": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./wasm": {
      "default": "./dist/typst_wasm_bg.wasm"
    }
  },
  "files": [
    "dist"
  ],
  "author": "will-lol",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/will-lol/typst-wasm.git"
  },
  "bugs": {
    "url": "https://github.com/will-lol/typst-wasm/issues"
  },
  "homepage": "https://github.com/will-lol/typst-wasm#readme",
  "devDependencies": {
    "@effect/eslint-plugin": "^0.3.2",
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.9",
    "@types/deno": "^2.5.0",
    "@types/node": "^25.2.0",
    "eslint": "^10.0.0",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "@typst-wasm/engine-wasm": "workspace:*",
    "@typst-wasm/fonts": "workspace:*",
    "effect": "^3.19.16",
    "nanotar": "^0.2.0",
    "tsdown-plugin-worker": "^0.1.6"
  }
}

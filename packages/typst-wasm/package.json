{
  "name": "typst-wasm",
  "version": "0.3.0",
  "description": "Typst WebAssembly compiler service with worker and JSPI backends",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": {
        "types": "./dist/index.browser.d.ts",
        "default": "./dist/index.browser.js"
      },
      "workerd": {
        "types": "./dist/index.workerd.d.ts",
        "default": "./dist/index.workerd.js"
      },
      "worker": {
        "types": "./dist/index.workerd.d.ts",
        "default": "./dist/index.workerd.js"
      },
      "default": "./dist/index.js"
    },
    "./files": {
      "types": "./dist/files.d.ts",
      "default": "./dist/files.js"
    }
  },
  "files": [
    "dist"
  ],
  "author": "will-lol",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wra-bradshaw/typst-wasm.git"
  },
  "bugs": {
    "url": "https://github.com/wra-bradshaw/typst-wasm/issues"
  },
  "homepage": "https://github.com/wra-bradshaw/typst-wasm#readme",
  "scripts": {
    "build": "nix run ../..#build-artifact -- typst-wasm",
    "fix": "pnpm run format:fix && pnpm exec eslint . --fix",
    "lint": "pnpm exec eslint . --max-warnings=0",
    "test": "pnpm run test:unit && pnpm run test:integration",
    "test:unit": "pnpm exec vitest run",
    "test:integration": "pnpm run test:integration:node && pnpm run test:integration:bun && pnpm run test:integration:deno",
    "test:integration:node": "node --experimental-wasm-stack-switching ./node_modules/vitest/vitest.mjs run -c vitest.integration.config.ts --pool vmThreads",
    "test:integration:bun": "sh -c 'if command -v bun >/dev/null 2>&1; then bun test ./tests/integration/bun.integration.ts; else echo \"Skipping Bun integration: bun not found\"; fi'",
    "test:integration:deno": "sh -c 'if command -v deno >/dev/null 2>&1; then deno test --no-check --allow-read --allow-net tests/integration/deno.integration.ts; else echo \"Skipping Deno integration: deno not found\"; fi'",
    "format": "pnpm exec prettier . --check",
    "format:fix": "pnpm exec prettier . --write",
    "knip": "pnpm exec knip"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.9",
    "@types/deno": "^2.5.0",
    "@types/node": "^25.2.0",
    "eslint": "^10.0.0",
    "knip": "^6.17.1",
    "prettier": "^3.8.4",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "@typst-wasm/engine-wasm": "workspace:*",
    "@typst-wasm/fonts": "workspace:*",
    "nanotar": "^0.2.0",
    "tsdown-plugin-worker": "^0.1.6"
  }
}

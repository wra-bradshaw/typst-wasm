{
  "name": "@typst-wasm/engine-wasm",
  "version": "0.3.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/typst-wasm/typst-wasm.git"
  },
  "bugs": {
    "url": "https://github.com/typst-wasm/typst-wasm/issues"
  },
  "homepage": "https://github.com/typst-wasm/typst-wasm#readme",
  "exports": {
    "./worker": {
      "types": "./dist/worker/engine.d.ts",
      "default": "./dist/worker/engine.js"
    },
    "./jspi": {
      "types": "./dist/jspi/engine.d.ts",
      "default": "./dist/jspi/engine.js"
    },
    "./jspi/engine.core.wasm": "./dist/jspi/engine.core.wasm",
    "./jspi/engine.core2.wasm": "./dist/jspi/engine.core2.wasm",
    "./jspi/engine.core3.wasm": "./dist/jspi/engine.core3.wasm",
    "./worker/engine.core.wasm": "./dist/worker/engine.core.wasm",
    "./worker/engine.core2.wasm": "./dist/worker/engine.core2.wasm",
    "./worker/engine.core3.wasm": "./dist/worker/engine.core3.wasm"
  },
  "scripts": {
    "build": "nix run ../..#build-artifact -- engine-wasm",
    "transpile:jspi": "node --experimental-strip-types scripts/transpile.mts jspi",
    "transpile:worker": "node --experimental-strip-types scripts/transpile.mts worker",
    "transpile": "pnpm transpile:worker && pnpm transpile:jspi",
    "fix": "cargo fmt --all && cargo clippy --fix --allow-dirty --allow-staged --target wasm32-unknown-unknown",
    "lint": "cargo clippy --target wasm32-unknown-unknown -- -D warnings",
    "format": "cargo fmt --all -- --check",
    "format:fix": "cargo fmt --all"
  },
  "devDependencies": {
    "@bytecodealliance/jco": "^1.24.6",
    "@types/node": "^25.5.2"
  },
  "files": [
    "dist"
  ]
}

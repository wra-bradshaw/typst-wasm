{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "flake.nix",
    "flake.lock",
    "package.json",
    "pnpm-lock.yaml",
    "pnpm-workspace.yaml",
    "scripts/**"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".cargo/**",
        "Cargo.toml",
        "Cargo.lock",
        "package.nix",
        "flake-module.nix",
        "scripts/**",
        "src/**"
      ],
      "outputs": ["dist/**", ".output/**"]
    },
    "lint": {
      "dependsOn": []
    },
    "test": {
      "dependsOn": ["build"]
    },
    "format": {
      "dependsOn": []
    },
    "test:integration": {
      "dependsOn": ["^build", "build"]
    }
  }
}
